# ==========================================
# JobDiscovery SaaS Environment Configurations
# ==========================================

# Core Application Settings
APP_NAME="AI Job Discovery SaaS"
DEBUG=true
ENVIRONMENT=development # Set to 'staging' or 'production' in other environments

# Security & Session Credentials
SECRET_KEY="production-grade-super-secret-key-change-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Google OAuth Credentials (Loaded only via Env - Do Not Hardcode)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# PostgreSQL Database Connection
DATABASE_URL="postgresql+asyncpg://postgres:postgres@db:5432/jobdiscovery"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=jobdiscovery

# Redis Broker (Celery & Caching)
REDIS_URL="redis://redis:6379/0"

# OpenAI API Key (Embeddings & Recommendation Explanations)
OPENAI_API_KEY="sk-proj-placeholder-key"

# Supabase Storage Credentials (Fallback to Local disk enabled only in development/staging)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_KEY="your-supabase-service-role-or-anon-key"
SUPABASE_BUCKET_NAME="resumes"

# n8n Webhook Secret (Workflow Orchestration)
N8N_WEBHOOK_SECRET="n8n-webhook-signing-secret"

# Email Configuration (SMTP Client)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="placeholder-smtp-user@gmail.com"
SMTP_PASSWORD="placeholder-smtp-app-password"
EMAILS_FROM_EMAIL="noreply@jobdiscovery.com"
EMAILS_FROM_NAME="JobDiscovery AI"

# Dynamic Celery Beat Digest Schedules
DAILY_DIGEST_HOUR=8
DAILY_DIGEST_MINUTE=0
WEEKLY_DIGEST_HOUR=8
WEEKLY_DIGEST_MINUTE=0
WEEKLY_DIGEST_DAY_OF_WEEK="1" # 1 = Monday
